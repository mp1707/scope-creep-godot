[gd_resource type="Resource" script_class="RecipeDefinition" format=3]

[ext_resource type="Script" path="res://scripts/data/recipe_input_matcher.gd" id="1_matcher"]
[ext_resource type="Script" path="res://scripts/data/duration_definition.gd" id="2_duration"]
[ext_resource type="Script" path="res://scripts/data/effect_definition.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/data/recipe_definition.gd" id="4_recipe"]

[sub_resource type="Resource" id="Duration_release_checked"]
script = ExtResource("2_duration")
base_seconds = 6.0

[sub_resource type="Resource" id="Effect_consume_checked_feature"]
script = ExtResource("3_effect")
id = "effect.consume_input.checked_feature"
effect_type = "consume_input"
parameters = {
"card_definition_id": "card.output.checked_feature"
}

[sub_resource type="Resource" id="Effect_spawn_money_feature_value"]
script = ExtResource("3_effect")
id = "effect.modify_card_value.software_feature_count.checked"
effect_type = "modify_card_value"
parameters = {
"card_definition_id": "card.product.software",
"delta": 1,
"key": "feature_count"
}

[sub_resource type="Resource" id="Input_checked_feature"]
script = ExtResource("1_matcher")
card_definition_id = "card.output.checked_feature"

[sub_resource type="Resource" id="Input_software"]
script = ExtResource("1_matcher")
card_definition_id = "card.product.software"

[resource]
script = ExtResource("4_recipe")
id = "recipe.money_from_checked_feature.software"
display_text = "Geprueftes Feature integrieren"
inputs = Array[ExtResource("1_matcher")]([SubResource("Input_checked_feature"), SubResource("Input_software")])
duration = SubResource("Duration_release_checked")
priority = 20
specificity_score = 2
effects_on_complete = Array[ExtResource("3_effect")]([SubResource("Effect_spawn_money_feature_value"), SubResource("Effect_consume_checked_feature")])
