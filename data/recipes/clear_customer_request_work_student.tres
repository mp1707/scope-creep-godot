[gd_resource type="Resource" script_class="RecipeDefinition" format=3]

[ext_resource type="Script" path="res://scripts/data/recipe_input_matcher.gd" id="1_matcher"]
[ext_resource type="Script" path="res://scripts/data/duration_definition.gd" id="2_duration"]
[ext_resource type="Script" path="res://scripts/data/effect_definition.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/data/recipe_definition.gd" id="4_recipe"]

[sub_resource type="Resource" id="Duration_clear_request"]
script = ExtResource("2_duration")
base_seconds = 4.5

[sub_resource type="Resource" id="Effect_consume_customer_request"]
script = ExtResource("3_effect")
id = "effect.consume_input.customer_request.work_student"
effect_type = "consume_input"
parameters = {
"card_definition_id": "card.input.customer_request"
}

[sub_resource type="Resource" id="Input_customer_request"]
script = ExtResource("1_matcher")
card_definition_id = "card.input.customer_request"

[sub_resource type="Resource" id="Input_work_student"]
script = ExtResource("1_matcher")
card_definition_id = "card.temp_worker.work_student"

[resource]
script = ExtResource("4_recipe")
id = "recipe.clear_customer_request.work_student"
display_text = "Kundenwunsch mitnehmen"
inputs = Array[ExtResource("1_matcher")]([SubResource("Input_customer_request"), SubResource("Input_work_student")])
duration = SubResource("Duration_clear_request")
priority = 5
specificity_score = 2
effects_on_complete = Array[ExtResource("3_effect")]([SubResource("Effect_consume_customer_request")])
duration_modifier_tags = PackedStringArray("planning_work", "temp_worker_duration")
