[gd_resource type="Resource" script_class="RecipeDefinition" format=3]

[ext_resource type="Script" path="res://scripts/data/recipe_input_matcher.gd" id="1_matcher"]
[ext_resource type="Script" path="res://scripts/data/duration_definition.gd" id="2_duration"]
[ext_resource type="Script" path="res://scripts/data/effect_definition.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/data/recipe_definition.gd" id="4_recipe"]

[sub_resource type="Resource" id="Duration_order"]
script = ExtResource("2_duration")
base_seconds = 1.0
affected_by_global_modifiers = false

[sub_resource type="Resource" id="Effect_spawn_bonus_money"]
script = ExtResource("3_effect")
id = "effect.spawn_money.freelance_order.checked"
effect_type = "spawn_money"
parameters = {
"count_key": "freelance_order_payout_money_cards"
}

[sub_resource type="Resource" id="Effect_consume_order"]
script = ExtResource("3_effect")
id = "effect.consume_input.order.checked"
effect_type = "consume_input"
parameters = {
"card_definition_id": "card.value_source.order"
}

[sub_resource type="Resource" id="Effect_consume_checked_feature"]
script = ExtResource("3_effect")
id = "effect.consume_input.checked_feature.freelance_order"
effect_type = "consume_input"
parameters = {
"card_definition_id": "card.output.checked_feature"
}

[sub_resource type="Resource" id="Input_order"]
script = ExtResource("1_matcher")
card_definition_id = "card.value_source.order"

[sub_resource type="Resource" id="Input_checked_feature"]
script = ExtResource("1_matcher")
card_definition_id = "card.output.checked_feature"

[resource]
script = ExtResource("4_recipe")
id = "recipe.money_from_order.checked_feature"
display_text = "Geprueften Auftrag liefern"
inputs = Array[ExtResource("1_matcher")]([SubResource("Input_order"), SubResource("Input_checked_feature")])
duration = SubResource("Duration_order")
priority = 30
specificity_score = 2
effects_on_complete = Array[ExtResource("3_effect")]([SubResource("Effect_spawn_bonus_money"), SubResource("Effect_consume_order"), SubResource("Effect_consume_checked_feature")])
