[gd_resource type="Resource" script_class="RecipeDefinition" format=3]

[ext_resource type="Script" path="res://scripts/data/recipe_input_matcher.gd" id="1_matcher"]
[ext_resource type="Script" path="res://scripts/data/duration_definition.gd" id="2_duration"]
[ext_resource type="Script" path="res://scripts/data/effect_definition.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/data/recipe_definition.gd" id="4_recipe"]

[sub_resource type="Resource" id="Duration_buy"]
script = ExtResource("2_duration")
base_seconds = 0.18

[sub_resource type="Resource" id="Effect_consume_money"]
script = ExtResource("3_effect")
id = "effect.consume_input.money.talent_pool_buy"
effect_type = "consume_input"
parameters = {
"card_definition_id": "card.resource.money",
"count": 2
}

[sub_resource type="Resource" id="Effect_spawn_booster_pack"]
script = ExtResource("3_effect")
id = "effect.spawn_card.booster_pack.talent_pool"
effect_type = "spawn_card"
parameters = {
"card_definition_id": "card.resource.booster_pack",
"copy_values_from_card_definition_id": "card.shop.booster_slot.talent_pool",
"count": 1
}

[sub_resource type="Resource" id="Input_money"]
script = ExtResource("1_matcher")
card_definition_id = "card.resource.money"
required_tags = PackedStringArray()
count = 2

[sub_resource type="Resource" id="Input_talent_pool_slot"]
script = ExtResource("1_matcher")
card_definition_id = "card.shop.booster_slot.talent_pool"
required_tags = PackedStringArray()

[resource]
script = ExtResource("4_recipe")
id = "recipe.booster_pack_from_two_money.talent_pool_slot"
display_text = "Talent-Pool kaufen"
inputs = Array[ExtResource("1_matcher")]([SubResource("Input_money"), SubResource("Input_talent_pool_slot")])
duration = SubResource("Duration_buy")
priority = 20
specificity_score = 4
effects_on_complete = Array[ExtResource("3_effect")]([SubResource("Effect_consume_money"), SubResource("Effect_spawn_booster_pack")])
